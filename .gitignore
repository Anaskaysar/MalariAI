# ============================================================
# MalariAI — .gitignore
# Public repo: code + results JSONs + paper source only.
# Data, checkpoints, internal docs, and build artifacts stay local.
# ============================================================

# ── Virtual environments ─────────────────────────────────────
malariaenv/
venv/
.venv/
env/

# ── Datasets (download separately per dataset licence) ───────
data/malaria/images/
data/malaria.zip
data/*.zip
data/crops/
data/MP-IDB/img/
data/MP-IDB/meta/
# Annotation JSONs and CSVs are small and kept:
# data/MP-IDB/ann/  ← kept (JSON annotations)
# data/processed/   ← kept (derived CSVs, reproducibility)

# ── Model checkpoints (too large; host on HuggingFace Hub) ───
*.pth
*.pt
*.ckpt

# ── Phase-specific artefacts ──────────────────────────────────
Phase2-BaselineA/checkpoints/
Phase2-BaselineA/checkpoints-kaggle-80epoch/
Phase2-BaselineA/checkpoints-local-20epoch/
Phase2-BaselineA/results/
Phase2-BaselineA/0.8
Phase3-PipelineB/checkpoints/
Phase3-PipelineB/checkpoints_v2/
Phase3-PipelineB/Phase3-PipelineB/
Phase4-WebApp/checkpoints/
Phase4-WebApp/static/uploads/

# ── Internal working documents (not for public) ───────────────
paper_writing/draft/
paper_writing/previous_study/
paper_writing/research_strategy_*.md
paper_writing/malariai_project_master_plan.html
paper_writing/malaria_literature_landscape.html
paper_writing/coauthor_reading_guide.md
paper_writing/v2_figures/
paper_writing/v2_results/
paper_writing/cmig_submission/system_diagram_brief.md
paper_writing/cmig_submission/system_diagram_v1.png

