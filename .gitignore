*.aux
*.log
*.out
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.pdf

# ── Utility / scratch scripts ─────────────────────────────────
scripts/
archive/
problem_statement.md
run.bat
run.ps1
run.sh

# ── Temporary eval runs ───────────────────────────────────────
results/v2/e2e_bbbc041_altmetrics/

# ── Python cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Packaging ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
wheels/

# ── Testing ───────────────────────────────────────────────────
